# GitHub token (fine-grained, read-only is enough). Without it you get 60 req/hr.
GITHUB_TOKEN=

# Port the server listens on (default 8787).
PORT=8787

# --- /judge model (all OPTIONAL) ---------------------------------------------
# /judge works with NO key at all: it returns a free heuristic rubric-signal scan.
# For automated MODEL judgments, set ONE of the following.

# Option A (FREE, recommended): any OpenAI-compatible endpoint + a free key.
#   Google AI Studio (Gemini) - free, no credit card:  https://aistudio.google.com/apikey
JUDGE_API_KEY=
JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
JUDGE_MODEL=gemini-2.0-flash
#   Groq (free, fast):   JUDGE_BASE_URL=https://api.groq.com/openai/v1   JUDGE_MODEL=llama-3.3-70b-versatile
#   NVIDIA NIM (free):   JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1   JUDGE_MODEL=meta/llama-3.3-70b-instruct

# Option B (paid): Anthropic Claude. If set, it takes precedence over JUDGE_API_KEY.
ANTHROPIC_API_KEY=
