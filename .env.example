# GitHub token (fine-grained, read-only is enough). Without it you get 60 req/hr.
GITHUB_TOKEN=

# Port the server listens on (default 8787).
PORT=8787

# --- /judge model (all OPTIONAL) ---------------------------------------------
# /judge works with NO key at all: it returns a free heuristic rubric-signal scan.
# For automated MODEL judgments you have three options.

# Option A (FREE, single model): any OpenAI-compatible endpoint + a free key.
#   Google AI Studio (Gemini) - free, no credit card:  https://aistudio.google.com/apikey
JUDGE_API_KEY=
JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
JUDGE_MODEL=gemini-flash-lite-latest

# Option B (FREE, ENSEMBLE - recommended): up to 4 free models (slots A-D) run IN PARALLEL
# and their answers are fused into ONE centralized verdict with an agreement/confidence
# signal (a synthesis pass reconciles them; a disagreement is flagged, never hidden).
# The legacy JUDGE_API_KEY above is ALSO included as a member - so setting A+B alongside a
# Gemini JUDGE_API_KEY gives a 3-model consensus (GLM + Groq + Gemini).
#   Provider A - Zhipu GLM-4.5-Flash (free, smart, 128K ctx):
JUDGE_A_LABEL=glm
JUDGE_A_KEY=
JUDGE_A_BASE_URL=https://open.bigmodel.cn/api/paas/v4
JUDGE_A_MODEL=glm-4.5-flash
#   Provider B - Groq (free, fast). JUDGE_B_SMALL=1 sends it a trimmed prompt so it stays under
#   Groq's tight free token-per-minute limit (auto-detected too).
#   !! DEPRECATION: llama-3.3-70b-versatile shuts down 2026-08-16. Migrate to openai/gpt-oss-120b
#      (verified live, a stronger reasoner) or qwen/qwen3-32b. Just change JUDGE_B_MODEL below.
JUDGE_B_LABEL=groq
JUDGE_B_KEY=
JUDGE_B_BASE_URL=https://api.groq.com/openai/v1
JUDGE_B_MODEL=openai/gpt-oss-120b
JUDGE_B_SMALL=1
#   RECOMMENDED slot C - Cerebras gpt-oss-120b: the single highest-value ADD. It restores an ODD 3rd
#   vote that does NOT share Groq's daily-token exhaustion, so freeHelpers ties stop capping TS
#   class-hierarchy repos (typeorm/mikro-orm) at PROVISIONAL. Free, no card; SMALL=1 (8K ctx cap).
JUDGE_C_LABEL=cerebras
JUDGE_C_KEY=
JUDGE_C_BASE_URL=https://api.cerebras.ai/v1
JUDGE_C_MODEL=gpt-oss-120b
JUDGE_C_SMALL=1
#   Other free options for slot D (same _KEY/_BASE_URL/_MODEL/_SMALL pattern):
#     OpenRouter (overflow/fallback, pin a SPECIFIC free id, NOT openrouter/free; privacy: free pool
#       may train on data -> public repos only): BASE=https://openrouter.ai/api/v1  MODEL=qwen/qwen3-coder:free
#     Self-hosted Ollama (zero rate limits, zero data leakage -> safe for PRIVATE repos, deterministic):
#       BASE=http://localhost:11434/v1  MODEL=qwen3-coder  (any dummy KEY)
#   Bump slot A to a newer free GLM-Flash (GLM-4.6/4.7-Flash) for a quality gain at zero integration
#   cost -- verify the exact free model slug is live on bigmodel/Z.ai before pinning.
# Synthesis control: 'on' (default), 'off' (deterministic fusion only), or a provider label.
JUDGE_SYNTH=on

# Option C (paid): Anthropic Claude. If set, it takes precedence over the free paths ("use Claude").
ANTHROPIC_API_KEY=
